# ─────────────────────────────────────────
# Meta WhatsApp Cloud API
# ─────────────────────────────────────────

# Permanent system user token from Meta App Dashboard
WHATSAPP_TOKEN=

# Phone Number ID from WhatsApp Business > API Setup
PHONE_NUMBER_ID=

# Any random string you choose — must match what you enter in Meta webhook config
VERIFY_TOKEN=

# Optional: SHA-256 HMAC secret for verifying webhook payload signatures
WEBHOOK_SECRET=

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@localhost:5432/whatsapp_trust

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────

PORT=3000

# Secret for express-session (use a long random string)
SESSION_SECRET=change_this_to_a_long_random_string

# Node environment: development | production
NODE_ENV=development

# ─────────────────────────────────────────
# File Uploads (optional)
# ─────────────────────────────────────────

# Max upload file size in bytes (default 20 MB)
MAX_UPLOAD_BYTES=20971520

# Folder where uploaded media is stored locally before sending
UPLOAD_DIR=./uploads
